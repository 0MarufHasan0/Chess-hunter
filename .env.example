# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/discord-twitter-tracker

# Twitter Account Credentials (used for initial cookie generation)
TW_USER=your_twitter_username_here
TW_PASS=your_twitter_password_here
TW_EMAIL=your_twitter_email_here

# Polling and Filtering Configuration
# Default interval: runs every 7 minutes
POLL_INTERVAL_CRON=*/7 * * * *

# Default age threshold for new accounts (in hours)
NEW_ACCOUNT_HOURS=48
